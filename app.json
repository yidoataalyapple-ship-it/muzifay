{
  "expo": {
    "name": "Muzifay",
    "slug": "muzifay-new",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0B1E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.muzifay.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "GADApplicationIdentifier": "ca-app-pub-4492429510539065~4639555910"
      }
    },
    "android": {
      "package": "com.muzifay.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0B1E"
      },
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-4492429510539065~4639555910"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7e29ef8c-d0d6-4368-b5b4-1ac16c9c78a3"
      }
    },
    "owner": "ismaildomaltan",
    "updates": {
      "url": "https://u.expo.dev/7e29ef8c-d0d6-4368-b5b4-1ac16c9c78a3"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "plugins": []
  }
}
